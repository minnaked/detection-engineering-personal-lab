<!-- group tag is the root element in Wazuh rules -->

<group name="local,syslog,sshd,windows,sysmon,">

  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
  </rule>

  <rule id="100002" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\whoami\.exe$</field>
    <description>T1033 - System Owner Discovery: whoami.exe executed by $(win.eventdata.user) on $(win.system.computer)</description>
    <mitre>
      <id>T1033</id>
    </mitre>
    <group>sysmon_event1,discovery,t1033</group>
  </rule>

  <rule id="100003" level="12">
    <if_sid>100002</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)powershell\.exe$</field>
    <description>T1033 - whoami from PowerShell by $(win.eventdata.user) on $(win.system.computer)</description>
    <mitre>
      <id>T1033</id>
    </mitre>
    <group>sysmon_event1,discovery,t1033,high_fidelity</group>
  </rule>

  <rule id="100004" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^10$</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">(?i)0x1f1fff|0x1fffff|0x143a</field>
    <description>T1055 - Process Injection: Memory access from $(win.eventdata.sourceImage) into $(win.eventdata.targetImage)</description>
    <mitre>
      <id>T1055</id>
    </mitre>
    <group>sysmon_event10,injection,t1055</group>
  </rule>

  <rule id="100005" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\systeminfo\.exe$</field>
    <description>T1082 - System Information Discovery: systeminfo.exe by $(win.eventdata.user) on $(win.system.computer)</description>
    <mitre>
      <id>T1082</id>
    </mitre>
    <group>sysmon_event1,discovery,t1082</group>
  </rule>

  <rule id="100006" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.originalFileName" type="pcre2">(?i)sysinfo\.exe$</field>
    <description>T1082 - System Information Discovery: systeminfo renamed binary by $(win.eventdata.user) on $(win.system.computer)</description>
    <mitre>
      <id>T1082</id>
    </mitre>
    <group>sysmon_event1,discovery,t1082,evasion_resistant</group>
  </rule>

  <rule id="100007" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)systeminfo</field>
    <description>T1082 - System Information Discovery: systeminfo in commandLine on $(win.system.computer) by $(win.eventdata.user)</description>
    <mitre>
      <id>T1082</id>
    </mitre>
    <group>sysmon_event1,discovery,t1082</group>
  </rule>

  <rule id="100008" level="12">
    <if_sid>100005</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)powershell\.exe$</field>
    <description>T1082 - systeminfo from PowerShell by $(win.eventdata.user) on $(win.system.computer)</description>
    <mitre>
      <id>T1082</id>
    </mitre>
    <group>sysmon_event1,discovery,t1082,high_fidelity</group>
  </rule>

  <rule id="100009" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^8$</field>
    <description>T1055 - CreateRemoteThread from $(win.eventdata.sourceImage) into $(win.eventdata.targetImage) by $(win.eventdata.user)</description>
    <mitre>
      <id>T1055</id>
      <id>T1055.001</id>
    </mitre>
    <group>sysmon_event8,injection,t1055,high_fidelity</group>
  </rule>

  <rule id="100010" level="15">
    <if_sid>100009</if_sid>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)(lsass|svchost|explorer|winlogon)\.exe</field>
    <description>T1055 - CRITICAL: CreateRemoteThread into sensitive process $(win.eventdata.targetImage) by $(win.eventdata.sourceImage)</description>
    <mitre>
      <id>T1055</id>
      <id>T1055.001</id>
    </mitre>
    <group>sysmon_event8,injection,t1055,critical</group>
  </rule>

</group>
