<!-- Local rules -->
<group name="local,syslog,sshd,">
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
  </rule>
</group>

<group name="windows,sysmon,">

  <!-- T1033: whoami executed - any method -->
  <rule id="100002" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)whoami\.exe</field>
    <description>T1033 - System Discovery: whoami.exe executed by $(win.eventdata.user)</description>
    <mitre>
      <id>T1033</id>
    </mitre>
  </rule>

  <!-- T1033: whoami from PowerShell - higher severity -->
  <rule id="100003" level="12">
    <if_sid>100002</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)powershell\.exe</field>
    <description>T1033 - whoami launched from PowerShell by $(win.eventdata.user) - post-exploitation indicator</description>
    <mitre>
      <id>T1033</id>
    </mitre>
  </rule>

  <!-- T1055: Process Injection - full access granted -->
  <rule id="100004" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^10$</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">0x1[Ff]{4}[Ff]{2}</field>
    <description>T1055 - Process Injection: Full memory access from $(win.eventdata.sourceImage) into $(win.eventdata.targetImage)</description>
    <mitre>
      <id>T1055</id>
    </mitre>
  </rule>

</group>
